+// SafeWriteFile loads dirPath into an in-memory filesystem, applies the same
+// modifications as WriteFile to the in-memory copy, and returns the filesystem
+// and working directory path within it. The source directory is never modified,
+// which eliminates the read-only FS, concurrent-build race, and orphaned-artifact
+// bugs inherent in WriteFile's in-place mutation cycle.
+func (g *Generator) SafeWriteFile(dirPath string) (memFS filesys.FileSystem, workDir string, action Action, err error) {
+	manifest, kfilePath, action, err := g.generateManifest(dirPath)
+	if err != nil {
+		return nil, "", action, err
+	}
+
+	workDir = "/src"
+	memFS = filesys.MakeFsInMemory()
+
+	if err := loadDirToMemFS(dirPath, workDir, memFS); err != nil {
+		return nil, "", action, fmt.Errorf("failed to load source dir: %w", err)
+	}
+
+	// Write the modified kustomization.yaml into the in-memory FS
+	rel, err := filepath.Rel(dirPath, kfilePath)
+	if err != nil {
+		return nil, "", action, err
+	}
+	if err := memFS.WriteFile(filepath.Join(workDir, rel), manifest); err != nil {
+		return nil, "", action, err
+	}
+
+	return memFS, workDir, action, nil
+}
