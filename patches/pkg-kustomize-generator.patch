+// loadDirToMemFS recursively loads all files from srcDir into an in-memory
+// filesystem under dstDir.
+func loadDirToMemFS(srcDir, dstDir string, fs filesys.FileSystem) error {
+	return filepath.Walk(srcDir, func(p string, info os.FileInfo, err error) error {
+		if err != nil {
+			return err
+		}
+
+		rel, err := filepath.Rel(srcDir, p)
+		if err != nil {
+			return err
+		}
+		target := filepath.Join(dstDir, rel)
+
+		if info.IsDir() {
+			return fs.MkdirAll(target)
+		}
+
+		data, err := os.ReadFile(p)
+		if err != nil {
+			return err
+		}
+		return fs.WriteFile(target, data)
+	})
 }
 
