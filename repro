#!/usr/bin/env bash
# vim: ft=bash
# Entrypoint: runs all flux kustomize bug reproduction scripts.
# Usage: ./repro [name...]
#   No arguments runs all. Pass names to run specific ones:
#   ./repro readonly concurrent-builds

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

tests=(
  "readonly:repro-readonly-fs:Read-only filesystem write failure"
  "concurrent-builds:repro-concurrent-builds:Concurrent flux build file contention"
  "tmp-exhaustion:repro-tmp-exhaustion:Orphaned artifacts from killed builds"
)

selected=()
if [ $# -eq 0 ]; then
  selected=("${tests[@]}")
else
  for arg in "$@"; do
    for t in "${tests[@]}"; do
      name="${t%%:*}"
      [ "$name" = "$arg" ] && selected+=("$t")
    done
  done
  if [ ${#selected[@]} -eq 0 ]; then
    echo "Unknown: $*"
    echo "Available: $(printf '%s ' "${tests[@]}" | gsed 's/:[^ ]*//g')"
    exit 1
  fi
fi

for t in "${selected[@]}"; do
  IFS=: read -r name script desc <<< "$t"
  echo ""
  echo "$desc"
  printf '%.0s-' $(seq 1 ${#desc}); echo ""
  "$SCRIPT_DIR/$script"
done
