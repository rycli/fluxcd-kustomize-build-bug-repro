#!/usr/bin/env bash
# vim: ft=bash
# Reproduces file contention when multiple flux build kustomization processes
# target the same source directory concurrently.
#
# Flux's kustomize generator calls WriteFile() which reads, modifies, and
# writes kustomization.yaml, then restores the original via CleanDirectory().
# Concurrent processes race on these read/write/restore operations.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
KUSTOMIZE_DIR="$SCRIPT_DIR/kustomize"
KS_FILE="$SCRIPT_DIR/kustomization.yaml"
N="${1:-30}"
strip() { gsed "s|$SCRIPT_DIR/||g"; }

ORIGINAL_CONTENT=$(cat "$KUSTOMIZE_DIR/kustomization.yaml")
cleanup() {
  echo "$ORIGINAL_CONTENT" > "$KUSTOMIZE_DIR/kustomization.yaml"
  rm -f "$KUSTOMIZE_DIR"/*.original
}
trap cleanup EXIT

echo "Spawning $N concurrent 'flux build kustomization' against ./kustomize"
echo "---"

pids=()
tmpdir="$SCRIPT_DIR/.tmp/concurrent-builds"
rm -rf "$tmpdir"
mkdir -p "$tmpdir"

for i in $(seq 1 "$N"); do
  (
    flux build kustomization repro-test \
      --path "$KUSTOMIZE_DIR" \
      --kustomization-file "$KS_FILE" \
      --dry-run \
      >"$tmpdir/stdout.$i" 2>"$tmpdir/stderr.$i"
    echo "$?" >"$tmpdir/exit.$i"
  ) &
  pids+=($!)
done

failures=0
for pid in "${pids[@]}"; do
  wait "$pid" || ((failures++)) || true
done

echo "Succeeded: $((N - failures))/$N"
echo "Failed:    $failures/$N"

for i in $(seq 1 "$N"); do
  [ -s "$tmpdir/stderr.$i" ] && echo "" && echo "process $i stderr:" && cat "$tmpdir/stderr.$i" | strip
done

if ! grep -q 'configmap.yaml' "$KUSTOMIZE_DIR/kustomization.yaml" 2>/dev/null; then
  echo "" && echo "kustomization.yaml after run:" && cat "$KUSTOMIZE_DIR/kustomization.yaml"
fi

ls "$KUSTOMIZE_DIR"/*.original 2>/dev/null | strip && echo "" && ls -la "$KUSTOMIZE_DIR"/*.original | strip
