#!/usr/bin/env ruby
# vim: ft=ruby
# Reproduces file contention when multiple flux build kustomization processes
# target the same source directory concurrently.
#
# Flux's kustomize generator calls WriteFile() which reads, modifies, and
# writes kustomization.yaml, then restores the original via CleanDirectory().
# Concurrent processes race on these read/write/restore operations.

require "fileutils"
require "open3"

SCRIPT_DIR    = File.dirname(File.realpath(__FILE__))
KUSTOMIZE_DIR = File.join(SCRIPT_DIR, "kustomize")
KS_FILE       = File.join(SCRIPT_DIR, "kustomization.yaml")
KS_YAML       = File.join(KUSTOMIZE_DIR, "kustomization.yaml")
N             = (ARGV[0] || 30).to_i

original_content = File.read(KS_YAML)

at_exit do
  File.write(KS_YAML, original_content)
  Dir.glob(File.join(KUSTOMIZE_DIR, "*.original")).each { |f| File.delete(f) }
end

strip = ->(s) { s.gsub("#{SCRIPT_DIR}/", "") }

puts "Spawning #{N} concurrent 'flux build kustomization' against ./kustomize"
puts "---"

results = Array.new(N)
threads = N.times.map do |i|
  Thread.new(i) do |idx|
    out, err, status = Open3.capture3(
      "flux", "build", "kustomization", "repro-test",
      "--path", KUSTOMIZE_DIR,
      "--kustomization-file", KS_FILE,
      "--dry-run"
    )
    results[idx] = { stdout: out, stderr: err, status: status }
  end
end
threads.each(&:join)

failures = results.count { |r| !r[:status].success? }
puts "Succeeded: #{N - failures}/#{N}"
puts "Failed:    #{failures}/#{N}"

results.each_with_index do |r, i|
  next if r[:stderr].empty?
  puts ""
  puts "process #{i + 1} stderr:"
  puts strip.call(r[:stderr])
end

unless File.read(KS_YAML).include?("configmap.yaml")
  puts ""
  puts "kustomization.yaml after run:"
  puts File.read(KS_YAML)
end

originals = Dir.glob(File.join(KUSTOMIZE_DIR, "*.original"))
unless originals.empty?
  puts ""
  originals.each { |f| puts strip.call(f) }
  puts ""
  originals.each { |f| puts strip.call(`ls -la #{f}`.chomp) }
end
