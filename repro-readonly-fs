#!/usr/bin/env ruby
# vim: ft=ruby
# Reproduces failures when flux build kustomization targets a read-only directory.
#
# Flux's WriteFile() writes a modified kustomization.yaml and creates .original
# backups. On a read-only filesystem these writes fail with EPERM/EROFS.

require "fileutils"
require "open3"

SCRIPT_DIR = File.dirname(File.realpath(__FILE__))
KS_FILE    = File.join(SCRIPT_DIR, "kustomization.yaml")
RO_DIR     = File.join(SCRIPT_DIR, ".tmp", "ro-kustomize")

at_exit do
  FileUtils.chmod_R("u+w", RO_DIR) rescue nil
  FileUtils.rm_rf(RO_DIR)
end

FileUtils.rm_rf(RO_DIR)
FileUtils.mkdir_p(RO_DIR)
Dir.glob(File.join(SCRIPT_DIR, "kustomize", "*")).each { |f| FileUtils.cp(f, RO_DIR) }

puts "Making .tmp/ro-kustomize read-only"
FileUtils.chmod_R("a-w", RO_DIR)

puts "Running flux build kustomization against read-only directory..."
puts "---"

out, status = Open3.capture2e(
  "flux", "build", "kustomization", "repro-test",
  "--path", RO_DIR,
  "--kustomization-file", KS_FILE,
  "--dry-run"
)

puts out.gsub("#{SCRIPT_DIR}/", "")
puts "---"
puts "Exit code: #{status.exitstatus}"

exit status.exitstatus
