#!/usr/bin/env ruby
# vim: ft=ruby
# Demonstrates orphaned artifact accumulation when flux builds are killed.
#
# Flux's WriteFile creates .original backups and kustomize creates temp dirs.
# When killed (OOM, SIGKILL, pod eviction), defer-based cleanup never runs.
#
# With simple local manifests, builds complete too fast to reliably catch
# mid-write. This script uses concurrent builds + SIGKILL to maximize the
# window. More reproducible in-cluster with remote GitRepository sources.

require "fileutils"

SCRIPT_DIR = File.dirname(File.realpath(__FILE__))
KS_FILE    = File.join(SCRIPT_DIR, "kustomization.yaml")
WORK_DIR   = File.join(SCRIPT_DIR, ".tmp", "kill-test")
TMPDIR     = File.join(SCRIPT_DIR, ".tmp", "tmpdir-exhaust")
M          = (ARGV[0] || 50).to_i

ENV["TMPDIR"] = TMPDIR
FileUtils.rm_rf([TMPDIR, WORK_DIR])
FileUtils.mkdir_p([TMPDIR, WORK_DIR])
Dir.glob(File.join(SCRIPT_DIR, "kustomize", "*")).each { |f| FileUtils.cp(f, WORK_DIR) }

puts "Launching #{M} concurrent flux builds, then killing all via SIGKILL"
puts "---"

pids = M.times.map do
  Process.spawn(
    "flux", "build", "kustomization", "repro-test",
    "--path", WORK_DIR,
    "--kustomization-file", KS_FILE,
    "--dry-run",
    out: File::NULL, err: File::NULL
  )
end

sleep 0.03
pids.each { |pid| Process.kill("KILL", pid) rescue nil }
pids.each { |pid| Process.wait(pid) rescue nil }

originals = Dir.glob(File.join(WORK_DIR, "*.original")).size
tmpfiles  = Dir.children(TMPDIR).size rescue 0
ks_yaml   = File.join(WORK_DIR, "kustomization.yaml")
corrupted = !File.read(ks_yaml).include?("configmap.yaml") rescue true

puts "Leftover .original files: #{originals}"
puts "Orphaned TMPDIR entries:  #{tmpfiles}"
puts "kustomization.yaml corrupted: #{corrupted ? "YES" : "no"}"

strip = ->(s) { s.gsub("#{SCRIPT_DIR}/", "") }

if originals > 0
  puts ""
  Dir.glob(File.join(WORK_DIR, "*.original")).each { |f| puts strip.call(`ls -la #{f}`.chomp) }
end

if tmpfiles > 0
  puts ""
  Dir.children(TMPDIR).first(10).each { |f| puts strip.call(f) }
end
