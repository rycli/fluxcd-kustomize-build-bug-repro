#!/usr/bin/env bash
# vim: ft=bash
# Build the flux CLI binary with and without the fix using the forked submodules.
# Artifacts land in .tmp/bin/ (gitignored). Idempotent — safe to re-run.
# Produces two binaries: .tmp/bin/flux-before and .tmp/bin/flux-after

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FLUX2_DIR="$SCRIPT_DIR/fluxcd-flux2"
PKG_DIR="$SCRIPT_DIR/fluxcd-pkg"
BIN_DIR="$SCRIPT_DIR/.tmp/bin"
PATCH_DIR="$SCRIPT_DIR/patches"

cleanup() {
  echo ""
  echo "restoring submodules to clean state..."
  git -C "$PKG_DIR" checkout -- . 2>/dev/null || true
  git -C "$FLUX2_DIR" checkout -- . 2>/dev/null || true
}
trap cleanup EXIT

# -- reset submodules ------------------------------------------------------

git -C "$PKG_DIR" checkout -- . 2>/dev/null || true
git -C "$FLUX2_DIR" checkout -- . 2>/dev/null || true

# -- stub embedded manifests ------------------------------------------------
# cmd/flux/manifests.embed.go has //go:embed manifests/*.yaml which fails
# without at least one .yaml file. The real manifests need kustomize CLI to
# bundle, but flux build kustomization --dry-run never reads them.

mkdir -p "$FLUX2_DIR/cmd/flux/manifests"
if [ ! -f "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml" ]; then
  echo "# placeholder for go:embed" > "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml"
fi

mkdir -p "$BIN_DIR"

# -- build before-fix -------------------------------------------------------

echo "=== building flux-before (unpatched) ==="

cd "$FLUX2_DIR"
CGO_ENABLED=0 go build -ldflags="-s -w" -o "$BIN_DIR/flux-before" ./cmd/flux
echo "built: $BIN_DIR/flux-before"

# -- build after-fix --------------------------------------------------------

echo ""
echo "=== building flux-after (patched) ==="

git -C "$PKG_DIR" checkout -- . 2>/dev/null || true
echo "pkg: applying patch..."
git -C "$PKG_DIR" apply "$PATCH_DIR/pkg-kustomize-generator.patch"

git -C "$FLUX2_DIR" checkout -- . 2>/dev/null || true
mkdir -p "$FLUX2_DIR/cmd/flux/manifests"
echo "# placeholder for go:embed" > "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml"
echo "flux2: applying patch..."
git -C "$FLUX2_DIR" apply "$PATCH_DIR/flux2-build.patch"

cd "$FLUX2_DIR"
if ! grep -q "replace github.com/fluxcd/pkg/kustomize =>" go.mod; then
  printf '\nreplace github.com/fluxcd/pkg/kustomize => %s/kustomize\n' "$PKG_DIR" >> go.mod
  go mod tidy 2>/dev/null
fi

CGO_ENABLED=0 go build -ldflags="-s -w" -o "$BIN_DIR/flux-after" ./cmd/flux
echo "built: $BIN_DIR/flux-after"

echo ""
echo "done. run ./repro to compare both binaries."
