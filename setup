#!/usr/bin/env bash
# vim: ft=bash
# Clone FluxCD source and build the flux CLI binary with and without the fix.
# Artifacts land in .tmp/ (gitignored). Idempotent — skips clone if present.
# Produces two binaries: .tmp/bin/flux-before and .tmp/bin/flux-after

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FLUX2_DIR="$SCRIPT_DIR/.tmp/flux2"
PKG_DIR="$SCRIPT_DIR/.tmp/pkg"
BIN_DIR="$SCRIPT_DIR/.tmp/bin"
PATCH_DIR="$SCRIPT_DIR/patches"

# Pinned commits that the patches were generated against.
FLUX2_COMMIT="d9f51d047dbb2e3184539ca40740f7b6f808f8d7"
PKG_COMMIT="357bbcc3462ccf78cc17fd0b9b7d498b1848bf14"

# -- clone ------------------------------------------------------------------

if [ -d "$FLUX2_DIR/.git" ]; then
  echo "flux2: already cloned"
else
  echo "flux2: cloning..."
  git clone https://github.com/fluxcd/flux2.git "$FLUX2_DIR"
  git -C "$FLUX2_DIR" checkout "$FLUX2_COMMIT"
fi

if [ -d "$PKG_DIR/.git" ]; then
  echo "pkg: already cloned"
else
  echo "pkg: cloning..."
  git clone https://github.com/fluxcd/pkg.git "$PKG_DIR"
  git -C "$PKG_DIR" checkout "$PKG_COMMIT"
fi

# -- stub embedded manifests ------------------------------------------------
# cmd/flux/manifests.embed.go has //go:embed manifests/*.yaml which fails
# without at least one .yaml file. The real manifests need kustomize CLI to
# bundle, but flux build kustomization --dry-run never reads them.

mkdir -p "$FLUX2_DIR/cmd/flux/manifests"
if [ ! -f "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml" ]; then
  echo "# placeholder for go:embed" > "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml"
fi

mkdir -p "$BIN_DIR"

# -- build before-fix -------------------------------------------------------

echo ""
echo "=== building flux-before (unpatched) ==="

cd "$PKG_DIR"
git checkout -- . 2>/dev/null || true

cd "$FLUX2_DIR"
git checkout -- . 2>/dev/null || true
# re-add the manifests stub (checkout may have removed it)
mkdir -p "$FLUX2_DIR/cmd/flux/manifests"
echo "# placeholder for go:embed" > "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml"

CGO_ENABLED=0 go build -ldflags="-s -w" -o "$BIN_DIR/flux-before" ./cmd/flux
echo "built: $BIN_DIR/flux-before"

# -- build after-fix --------------------------------------------------------

echo ""
echo "=== building flux-after (patched) ==="

cd "$PKG_DIR"
git checkout -- . 2>/dev/null || true
echo "pkg: applying patch..."
git apply "$PATCH_DIR/pkg-kustomize-generator.patch"

cd "$FLUX2_DIR"
git checkout -- . 2>/dev/null || true
mkdir -p "$FLUX2_DIR/cmd/flux/manifests"
echo "# placeholder for go:embed" > "$FLUX2_DIR/cmd/flux/manifests/placeholder.yaml"
echo "flux2: applying patch..."
git apply "$PATCH_DIR/flux2-build.patch"

if ! grep -q "replace github.com/fluxcd/pkg/kustomize =>" go.mod; then
  printf '\nreplace github.com/fluxcd/pkg/kustomize => %s/kustomize\n' "$PKG_DIR" >> go.mod
  go mod tidy 2>/dev/null
fi

CGO_ENABLED=0 go build -ldflags="-s -w" -o "$BIN_DIR/flux-after" ./cmd/flux
echo "built: $BIN_DIR/flux-after"

echo ""
echo "done. run ./repro to compare both binaries."
